@model MediaItem
@{
    ViewData["Title"] = "Edit " + Model.Title;
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card p-4">
            <h4 class="mb-4">Edit: @Model.Title</h4>
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <div class="mb-3">
                    <label asp-for="Status" class="form-label">Status</label>
                    <select asp-for="Status" class="form-select" style="background:#0d1117; color:#e6edf3; border-color:#30363d;">
                        @foreach (WatchStatus s in Enum.GetValues(typeof(WatchStatus)))
                        {
                            <option value="@s">@s</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label asp-for="UserRating" class="form-label">Your Rating (1-10)</label>
                    <input asp-for="UserRating" type="number" min="1" max="10" class="form-control" style="background:#0d1117; color:#e6edf3; border-color:#30363d;" />
                </div>
                <div class="mb-4">
                    <label asp-for="UserNotes" class="form-label">Notes</label>
                    <textarea asp-for="UserNotes" rows="3" class="form-control" style="background:#0d1117; color:#e6edf3; border-color:#30363d;"></textarea>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Save</button>
                    <a href="/Dashboard" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
