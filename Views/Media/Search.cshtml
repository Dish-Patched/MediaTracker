@model SearchViewModel
@{
    ViewData["Title"] = "Add Media";
}

<div class="mb-4">
    <h1 class="h3 fw-bold"><i class="bi bi-search me-2 text-primary"></i>Add Media</h1>
    <p class="text-secondary">Search for movies, TV shows, books, or games to add to your collection.</p>
</div>

<div class="card p-4 mb-4">
    <form asp-action="Search" method="post">
        <div class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Media Type</label>
                <select asp-for="MediaType" class="form-select" style="background:#0d1117; color:#e6edf3; border-color:#30363d;">
                    <option value="@MediaType.Movie">Movie</option>
                    <option value="@MediaType.TvShow">TV Show</option>
                    <option value="@MediaType.Book">Book</option>
                    <option value="@MediaType.VideoGame">Video Game</option>
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label">Title</label>
                <input asp-for="Query" class="form-control" placeholder="Search by title..." style="background:#0d1117; color:#e6edf3; border-color:#30363d;" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-search me-1"></i>Search
                </button>
            </div>
        </div>
    </form>
</div>

@if (Model.Results.Any())
{
    <h5 class="mb-3 text-secondary">@Model.Results.Count results for "@Model.Query"</h5>
    <div class="row g-3">
        @foreach (var result in Model.Results)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card search-result-card h-100">
                    <div class="row g-0">
                        <div class="col-4">
                            @if (!string.IsNullOrEmpty(result.CoverImageUrl))
                            {
                                <img src="@result.CoverImageUrl" class="img-fluid rounded-start h-100" style="object-fit:cover; max-height:180px;" alt="@result.Title" loading="lazy" />
                            }
                            else
                            {
                                <div style="height:180px; background:#21262d; display:flex; align-items:center; justify-content:center; border-radius: 6px 0 0 6px; font-size:2rem; color:#484f58;">
                                    @switch (result.MediaType)
                                    {
                                        case MediaType.Movie: <i class="bi bi-film"></i> break;
                                        case MediaType.TvShow: <i class="bi bi-tv"></i> break;
                                        case MediaType.Book: <i class="bi bi-book"></i> break;
                                        default: <i class="bi bi-controller"></i> break;
                                    }
                                </div>
                            }
                        </div>
                        <div class="col-8">
                            <div class="card-body p-3 d-flex flex-column h-100">
                                <h6 class="card-title mb-1 fw-semibold">@result.Title</h6>
                                @if (!string.IsNullOrEmpty(result.ReleaseDate))
                                {
                                    <small class="text-secondary mb-1">@result.ReleaseDate</small>
                                }
                                @if (!string.IsNullOrEmpty(result.Creator))
                                {
                                    <small class="text-secondary mb-1 text-truncate">@result.Creator</small>
                                }
                                @if (!string.IsNullOrEmpty(result.Description))
                                {
                                    <p class="small text-secondary mb-2" style="display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; overflow:hidden;">
                                        @result.Description
                                    </p>
                                }
                                <div class="mt-auto">
                                    @if (result.Rating.HasValue)
                                    {
                                        <small class="text-warning me-2">&#9733; @result.Rating?.ToString("F1")</small>
                                    }
                                    <form asp-action="AddMedia" asp-controller="Media" method="post" class="d-inline">
                                        <input type="hidden" name="externalId" value="@result.ExternalId" />
                                        <input type="hidden" name="mediaType" value="@result.MediaType" />
                                        <button type="submit" class="btn btn-primary btn-sm">
                                            <i class="bi bi-plus-lg me-1"></i>Add
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else if (!string.IsNullOrEmpty(Model.Query))
{
    <div class="text-center py-5">
        <i class="bi bi-search text-secondary" style="font-size:3rem;"></i>
        <p class="mt-3 text-secondary">No results found for "@Model.Query"</p>
    </div>
}
